# ── OCR ────────────────────────────────────────────────────────────────
UPSTAGE_API_KEY=your_upstage_api_key_here

# ── LLM 백엔드 ─────────────────────────────────────────────────────────
# mlx  → Apple Silicon 로컬 (기본)
# gguf → llama-cpp-python GGUF 파일
MODEL_BACKEND=mlx

# MLX 모델 (MODEL_BACKEND=mlx 일 때)
MLX_MODEL=mlx-community/gemma-4-e4b-it-4bit

# GGUF 모델 파일 경로 (MODEL_BACKEND=gguf 일 때)
# GGUF_MODEL_PATH=./models/gemma-4-e4b-it-Q4_K_M.gguf
# GGUF_N_CTX=8192
# GGUF_N_GPU_LAYERS=-1

# ── Qdrant (RAG) ───────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=workguard_docs
DOCUMENTS_DIR=./documents

# ── SQLite ────────────────────────────────────────────────────────────
DB_PATH=./data/workguard.db

# ── 임베딩 모델 ─────────────────────────────────────────────────────────
DENSE_MODEL=BAAI/bge-base-en-v1.5
SPARSE_MODEL=Qdrant/bm25
DENSE_DIM=768
