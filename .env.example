# ── API Keys ────────────────────────────────────────────────────────────
UPSTAGE_API_KEY=your_upstage_api_key_here

# ── LLM 백엔드 (server) ─────────────────────────────────────────────────
# mlx  → Apple Silicon 로컬 (기본)
# gguf → llama-cpp-python GGUF 파일
MODEL_BACKEND=mlx

# MLX 모델 (MODEL_BACKEND=mlx 일 때)
MLX_MODEL=mlx-community/gemma-4-e4b-it-4bit

# GGUF 모델 파일 경로 (MODEL_BACKEND=gguf 일 때)
# GGUF_MODEL_PATH=./models/gemma-4-e4b-it-Q4_K_M.gguf
# GGUF_N_CTX=8192
# GGUF_N_GPU_LAYERS=-1

# ── Qdrant ──────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
COLLECTION_NAME=workguard_docs

# ── 임베딩 (embedder) ───────────────────────────────────────────────────
DENSE_MODEL=solar-embedding-1-large-passage
SPARSE_MODEL=Qdrant/bm25
DENSE_DIM=4096
BATCH_SIZE=32
CHUNK_SIZE=1200
CHUNK_OVERLAP=320
LOG_LEVEL=INFO

# ── 경로 (docker-compose에서 override됨) ────────────────────────────────
DOCUMENTS_DIR=/app/documents
DB_PATH=/app/data/workguard.db
